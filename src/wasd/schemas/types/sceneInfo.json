{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "definitions": {
        "cam": {
            "type": "object",
            "properties": {
                "sourceName": {
                    "type": "string"
                },
                "crop": {
                    "type": "string",
                    "enum": [
                        "start",
                        "center",
                        "end",
                        "custom"
                    ]
                },
                "aspectRatio": {
                    "type": "string"
                }
            },
            "required": [
                "sourceName"
            ]
        }
    },
    "properties": {
        "name": {
            "type": "string"
        },
        "run": {
            "oneOf": [
                {
                    "$ref": "./RunData.json"
                },
                {
                    "type": "null"
                }
            ]
        },
        "camStack": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "direction": {
                        "enum": [
                            "horizontal",
                            "vertical"
                        ]
                    },
                    "gap": {
                        "type": "number"
                    },
                    "cams": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "cams": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/definitions/cam"
            }
        }
    },
    "required": [
        "name",
        "run"
    ]
}